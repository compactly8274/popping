# =============================================================================
# Popping configuration
# Copy to .env and edit. The docker-compose stack reads this file directly.
# =============================================================================

# --- Core --------------------------------------------------------------------

# Bind host for the FastAPI backend. Default: 127.0.0.1 (only reachable from
# the host). Set to 0.0.0.0 to expose on the docker network (still front it
# with authproxy in any non-local deployment).
POPPING_BACKEND_HOST=127.0.0.1
POPPING_BACKEND_PORT=8000

# Bind host for the Vite dev server.
POPPING_FRONTEND_HOST=127.0.0.1
POPPING_FRONTEND_PORT=5173

# --- Image source (GHCR prebuilt images) -----------------------------------
#
# Set POPPING_IMAGE_TAG to pin a specific version:
#   latest     (default) — tracks main
#   sha-<sha>            — exact commit
#   pr-<num>             — test a PR build
# Set POPPING_IMAGE_OWNER if you forked the repo.
# Set POPPING_PULL_POLICY=always to force a fresh pull on every `up`.
#
# To run from source instead (with hot-reload), use the dev override:
#   cp docker-compose.override.yml.example docker-compose.override.yml
#   docker compose up
#
POPPING_IMAGE_OWNER=compactly8274
POPPING_IMAGE_TAG=latest
POPPING_PULL_POLICY=missing

# --- Database ----------------------------------------------------------------

# Used by docker-compose to create the postgres role + database. The backend
# constructs DATABASE_URL from these.
POSTGRES_USER=popping
POSTGRES_PASSWORD=popping
POSTGRES_DB=popping

# --- Redis -------------------------------------------------------------------

REDIS_URL=redis://redis:6379/0

# --- LLM providers (all optional; phase 2+) ----------------------------------
#
# Each provider block is independent. Pick whichever you actually run. Phase 1
# never touches these.

# Ollama (local — recommended for embedding + scoring)
OLLAMA_BASE_URL=http://host.docker.internal:11434
OLLAMA_MODEL_SCORING=llama3.1:8b
OLLAMA_MODEL_BRIEF=llama3.1:8b
OLLAMA_MODEL_EMBEDDING=all-minilm

# Ollama Cloud (paid Ollama SaaS)
OLLAMA_CLOUD_API_KEY=
OLLAMA_CLOUD_MODEL_SCORING=
OLLAMA_CLOUD_MODEL_BRIEF=

# Groq
GROQ_API_KEY=
GROQ_MODEL_SCORING=llama-3.1-8b-instant
GROQ_MODEL_BRIEF=llama-3.1-70b-versatile

# Claude (Anthropic)
ANTHROPIC_API_KEY=
CLAUDE_MODEL_SCORING=claude-haiku-4-5
CLAUDE_MODEL_BRIEF=claude-sonnet-4-6

# OpenAI
OPENAI_API_KEY=
OPENAI_MODEL_SCORING=gpt-4o-mini
OPENAI_MODEL_BRIEF=gpt-4o

# --- Source API keys (phase 2+) ---------------------------------------------
KEEPA_API_KEY=
PODCAST_INDEX_API_KEY=
PODCAST_INDEX_API_SECRET=

# --- Notifications (phase 2+) ----------------------------------------------
PUSHOVER_USER_KEY=
PUSHOVER_APP_TOKEN=
APPRISE_URL=