# =============================================================================
# Popping configuration
# Copy to .env and edit. The docker-compose stack reads this file directly.
# =============================================================================

# --- Core --------------------------------------------------------------------

# Bind host for the Vite dev server (the only published port in the stack).
# Default: 0.0.0.0 (LAN-reachable). Set to 127.0.0.1 for host-only access.
POPPING_FRONTEND_HOST=0.0.0.0

# Non-standard port to avoid the usual 3000/5173/8000/8080 collisions.
# Change to whatever is free on the host.
POPPING_FRONTEND_PORT=14789

# --- Image source (GHCR prebuilt images) -----------------------------------
#
# Set POPPING_IMAGE_TAG to pin a specific version:
#   latest     (default) — tracks main
#   sha-<sha>            — exact commit
#   pr-<num>             — test a PR build
# Set POPPING_IMAGE_OWNER if you forked the repo.
# Set POPPING_PULL_POLICY=always to force a fresh pull on every `up`.
#
# To run from source instead (with hot-reload), use the dev override:
#   cp docker-compose.override.yml.example docker-compose.override.yml
#   docker compose up
#
POPPING_IMAGE_OWNER=compactly8274
POPPING_IMAGE_TAG=latest
POPPING_PULL_POLICY=missing

# --- Database ----------------------------------------------------------------

# Used by docker-compose to create the postgres role + database. The backend
# constructs DATABASE_URL from these.
POSTGRES_USER=popping
POSTGRES_PASSWORD=popping
POSTGRES_DB=popping

# --- Redis -------------------------------------------------------------------

REDIS_URL=redis://redis:6379/0

# --- LLM providers (all optional; phase 2+) ----------------------------------
#
# Each provider block is independent. Pick whichever you actually run. Phase 1
# never touches these.

# Ollama (local — recommended for embedding + scoring)
OLLAMA_BASE_URL=http://host.docker.internal:11434
OLLAMA_MODEL_SCORING=llama3.1:8b
OLLAMA_MODEL_BRIEF=llama3.1:8b
OLLAMA_MODEL_EMBEDDING=all-minilm

# Ollama Cloud (paid Ollama SaaS)
OLLAMA_CLOUD_API_KEY=
OLLAMA_CLOUD_MODEL_SCORING=
OLLAMA_CLOUD_MODEL_BRIEF=

# Groq
GROQ_API_KEY=
GROQ_MODEL_SCORING=llama-3.1-8b-instant
GROQ_MODEL_BRIEF=llama-3.1-70b-versatile

# Claude (Anthropic)
ANTHROPIC_API_KEY=
CLAUDE_MODEL_SCORING=claude-haiku-4-5
CLAUDE_MODEL_BRIEF=claude-sonnet-4-6

# OpenAI
OPENAI_API_KEY=
OPENAI_MODEL_SCORING=gpt-4o-mini
OPENAI_MODEL_BRIEF=gpt-4o

# --- Source API keys (phase 2+) ---------------------------------------------
KEEPA_API_KEY=
PODCAST_INDEX_API_KEY=
PODCAST_INDEX_API_SECRET=
# Optional GitHub PAT — bumps rate limit on the github_releases source from
# 60/hr to 5000/hr. Create at https://github.com/settings/tokens (no scopes
# needed for public release reads).
GITHUB_TOKEN=

# --- Notifications (phase 2+) ----------------------------------------------
# Phase 4 wires these up. The backend picks the first one that's set:
#   1. APPRISE_URL — opaque, covers 100+ services (Pushover, Telegram,
#      Discord, Slack, ntfy, email, ...). Examples:
#        pover://userkey/appkey
#        tgram://bottoken/chatid
#        discord://token/channel
#        ntfy://topic@ntfy.sh
#      See https://github.com/caronc/apprise/wiki for the full list.
#   2. PUSHOVER_USER_KEY + PUSHOVER_APP_TOKEN — direct fallback when
#      APPRISE_URL isn't set.
PUSHOVER_USER_KEY=
PUSHOVER_APP_TOKEN=
APPRISE_URL=

# --- Phase 4: The Brief + notifications ---------------------------------
# UTC hour at which the scheduler generates the daily brief. Set to -1
# to disable the scheduled run (manual button only). 0-23.
BRIEF_SCHEDULE_HOUR=8
# CVSS threshold (0-10) for the post-ingest CVE alert. Default 7.0
# (HIGH severity). Set to 0 to alert on every CVE ingest; set to 11 to
# disable the alert path entirely.
CVE_NOTIFY_MIN_CVSS=7.0
# Minimum number of distinct sources a slug must appear in (within
# CONVERGENCE_WINDOW_HOURS) to trigger a convergence alert Brief.
# Default 2.
CONVERGENCE_NOTIFY_THRESHOLD=2
# How often the convergence-check job runs. Cheap (one GROUP BY).
CONVERGENCE_CHECK_INTERVAL_MINUTES=15

# --- OIDC / login (optional) ------------------------------------------------
#
# When OIDC_ENABLED is false (the default), the dashboard runs as a
# single-user app with no login — fine for a local-only deployment. Flip
# it on for any LAN / public exposure.
#
# Provider notes:
#   - Authentik / Pocket-ID / Authelia (OIDC mode) / Keycloak / Auth0 /
#     Google all work; create a public client (no client secret) with
#     PKCE and set the redirect URI to "${PUBLIC_URL}/auth/callback".
#   - The backend fetches the IdP's discovery document on first /auth/login.
#
# Generate SESSION_SECRET with: openssl rand -hex 32
OIDC_ENABLED=false
OIDC_ISSUER=
OIDC_CLIENT_ID=
OIDC_SCOPES=openid email profile
PUBLIC_URL=
SESSION_SECRET=
SESSION_TTL_SECONDS=28800
SESSION_COOKIE_NAME=popping_session

# --- Local fallback user (optional) ---------------------------------------
#
# Hardcoded username + bcrypt-hashed password that bypasses OIDC. Useful
# when the IdP is down or you're testing without one. Reuses the same
# session cookie as OIDC, so a logged-in local user is indistinguishable
# downstream.
#
# Generate the hash with:
#   python -c "import bcrypt; print(bcrypt.hashpw(b'YOUR_PASSWORD', bcrypt.gensalt()).decode())"
LOCAL_AUTH_ENABLED=false
LOCAL_USER_NAME=
LOCAL_USER_PASSWORD_HASH=
LOCAL_USER_EMAIL=

# --- Local bypass (optional) ------------------------------------------------
#
# When true, requests from loopback (127.0.0.0/8, ::1) or any RFC1918 /
# IPv6 ULA / link-local address are treated as authenticated with a
# synthetic 'local-bypass' user — no login needed from the server's
# keyboard or the same LAN. Useful for headless deployments without a
# full OIDC stack.
#
# SECURITY: the IP is taken from the TCP peer only. X-Forwarded-For is
# ignored — it can be spoofed by any client and would let a LAN attacker
# claim a loopback identity. If you run behind a reverse proxy, terminate
# TLS at the proxy and have it speak to the backend on a private
# interface. Off by default for safety.
LOCAL_AUTH_BYPASS=false

# How often to delete expired session rows. The scheduler picks this up.
SESSION_PURGE_INTERVAL_SECONDS=3600

# --- Phase 2: embeddings ------------------------------------------------------
#
# sentence-transformers model used to embed entry text at ingest time.
# The default (all-MiniLM-L6-v2) produces 384-dim vectors and matches
# the Vector(384) column on entries. Runs on CPU. Set EMBEDDING_ENABLED=false
# to skip the pipeline entirely on memory-constrained hosts; entries then
# store NULL embedding and personal scoring collapses to recency + source.
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
EMBEDDING_BATCH_SIZE=64
EMBEDDING_ENABLED=true

# --- Phase 2: composite scoring weights ---------------------------------------
#
# Final score a card sorts by:
#   composite = w_r * recency + w_p * personal + w_s * (raw_score * source_weight)
#
# Weights don't have to sum to 1 — they're multipliers, not probabilities —
# but the defaults do.
SCORING_WEIGHT_RECENCY=0.4
SCORING_WEIGHT_PERSONAL=0.4
SCORING_WEIGHT_SOURCE=0.2

# --- Phase 2: convergence boost ----------------------------------------------
#
# Items sharing a normalized title (lowercased, punctuation-stripped, first
# 8 words) within the window get a multiplicative boost on their composite
# score. 2 sources → CONVERGENCE_BOOST_2; 3+ sources → CONVERGENCE_BOOST_3PLUS.
CONVERGENCE_WINDOW_HOURS=24
CONVERGENCE_BOOST_2=1.10
CONVERGENCE_BOOST_3PLUS=1.20